      <visual name="camera_body">
        <!-- relative to stand_link frame (which is already at z=0.25) -->
        <pose>0 0 0.265 0 0 0</pose> <!-- 0.25 + 0.265 = 0.515m above ground, sitting flat on stand -->
        <geometry>
          <box><size>0.08 0.04 0.03</size></box>
        </geometry>
      </visual>

        <plugin name="gazebo_ros_openni_kinect" filename="libgazebo_ros_depth_camera.so">
          <robotNamespace>/demo</robotNamespace>
          <frameName>rgbd_camera_link</frameName>

          <!-- RGB topics -->
